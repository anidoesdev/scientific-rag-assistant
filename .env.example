# ── Scientific RAG Assistant – environment variables ─────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# ── OpenAI ──────────────────────────────────────────────────────────────────
#OPENAI_API_KEY=sk-...

# ── PostgreSQL (only needed when running WITHOUT Docker Compose) ─────────────
# DB_HOST=localhost
# DB_PORT=5732
# DB_USER=raguser
# DB_PASSWORD=ragpassword
# DB_NAME=ragdb

# ── Redis (only needed when running WITHOUT Docker Compose) ─────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6380

# ── Auth ─────────────────────────────────────────────────────────────────────
# Google OAuth client ID (from Google Cloud Console → APIs & Services → Credentials)
#GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Random secret used to sign JWTs — generate with: python -c "import secrets; print(secrets.token_hex(32))"
#JWT_SECRET_KEY=change-me-in-production
# Same client ID, exposed to the browser bundle (Next.js NEXT_PUBLIC_ prefix required)
#NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── VM / production ──────────────────────────────────────────────────────────
# URL the *browser* uses to reach the API (baked into the Next.js bundle at build time)
#NEXT_PUBLIC_API_URL=http://YOUR_VM_IP:8000
# Comma-separated origins the backend will accept (add your VM's IP/domain here)
#ALLOWED_ORIGINS=http://localhost:3000,http://YOUR_VM_IP:3000

# ── Optional tuning ──────────────────────────────────────────────────────────
# CACHE_TTL_SECONDS=3600
# GENERATION_MODEL=gpt-4o-mini
# RERANKER_MODEL=gpt-4o-mini
# RETRIEVAL_FINAL_K=5
