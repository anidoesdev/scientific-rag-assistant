# ── Scientific RAG Assistant – environment variables ─────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── PostgreSQL (only needed when running WITHOUT Docker Compose) ─────────────
# DB_HOST=localhost
# DB_PORT=5732
# DB_USER=raguser
# DB_PASSWORD=ragpassword
# DB_NAME=ragdb

# ── Redis (only needed when running WITHOUT Docker Compose) ─────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Ollama (only needed when running WITHOUT Docker Compose) ─────────────────
# OLLAMA_HOST=http://localhost:11434

# ── Optional tuning ──────────────────────────────────────────────────────────
# CACHE_TTL_SECONDS=3600
# GENERATION_MODEL=gpt-5-mini
# RERANKER_MODEL=gpt-5-mini
# RETRIEVAL_FINAL_K=5
